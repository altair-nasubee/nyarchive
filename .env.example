# --- Database (Turso / libSQL) ---
# 本番は Turso のURLとトークン。ローカル開発は file:local.db でも可。
TURSO_DATABASE_URL="file:local.db"
TURSO_AUTH_TOKEN=""

# --- Better Auth ---
# `openssl rand -base64 32` で生成
BETTER_AUTH_SECRET=""
# アプリのベースURL（本番は https://your-domain）
BETTER_AUTH_URL="http://localhost:3000"

# --- Google OAuth ---
# https://console.cloud.google.com/ で作成
# 承認済みリダイレクトURI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Vercel Blob ---
BLOB_READ_WRITE_TOKEN=""

# --- 管理者（オーナー）のメールアドレス ---
ADMIN_EMAIL="altair@nasubee.com"
